# ==========================================
# Argus — The AI Trading Guardian
# Copy to .env. All values are optional: without Bitget keys Argus runs on
# deterministic simulated data so the demo always works.
# ==========================================

# ==========================================
# BITGET API CREDENTIALS
# ==========================================
BITGET_API_KEY=your_api_key_here
BITGET_SECRET_KEY=your_secret_key_here
BITGET_PASSPHRASE=your_passphrase_here

# ==========================================
# LIVE MARKET DATA (Bitget public REST — no key required)
# ==========================================
# Argus reads live, public Bitget market data (ticker + candles) for analysis.
# This needs NO credentials. Set to false to force the offline synthetic feed.
ARGUS_LIVE_DATA=true

# ==========================================
# AI PROVIDER — Qwen-first (OpenAI optional fallback)
# ==========================================
# Argus reasoning/reflection is powered by Qwen by default. OpenAI is only used
# as a fallback if you set OPENAI_API_KEY. With no key set, Argus runs on its
# deterministic rule-based engine (no fabricated reasoning).
ARGUS_LLM_PROVIDER=qwen
ARGUS_QWEN_MODEL=dashscope/qwen-plus
ARGUS_OPENAI_MODEL=gpt-4o-mini
DASHSCOPE_API_KEY=your_qwen_dashscope_key_here
# OPENAI_API_KEY=optional_fallback_only

# ==========================================
# TRADING MODE
# ==========================================
# Argus is execution-ready but PAPER by default. Reaching a real Bitget order
# requires clearing FOUR independent gates — so no real trade can happen by
# accident or on the hosted judging demo:
#   1. PAPER_TRADING=False              (below)
#   2. ARGUS_ALLOW_LIVE_TRADING=true    (deployment master switch, below)
#   3. Bitget credentials present       (above)
#   4. Arm live mode in the Execution Console by typing "ENABLE LIVE TRADING"
# Each live order also passes an explicit per-order confirm. Leave these at the
# safe defaults unless you fully intend to trade real funds.
#
# ⚠️  DANGER: enabling live execution trades REAL money. Before doing so:
#   - Review risk_guardian.py circuit breakers and MAX_DAILY_LOSS_PCT
#   - Start with MAX_POSITION_PCT=0.02 (2%) and monitor the first cycles manually
PAPER_TRADING=True

# Deployment master switch for live trading. Unset/false = hard-locked to PAPER.
ARGUS_ALLOW_LIVE_TRADING=false
# Exercise the full signed live-order path WITHOUT transmitting (safe rehearsal):
# ARGUS_LIVE_ORDER_DRYRUN=true

# ==========================================
# AGENT CONFIGURATION
# ==========================================
# Argus scans a BROAD Bitget universe, not just BTC/ETH. By default the Market
# Scanner uses DYNAMIC DISCOVERY — it pulls the most actively traded USDT pairs
# live from Bitget (services/bitget.py: discover_symbols), so the list below is
# only a seed/fallback and an optional override for the legacy cycle runner.
SYMBOLS=["BTCUSDT", "ETHUSDT", "SOLUSDT", "BNBUSDT", "XRPUSDT", "DOGEUSDT", "SUIUSDT", "APTUSDT", "ARBUSDT", "OPUSDT", "LINKUSDT", "AVAXUSDT", "INJUSDT", "TIAUSDT", "ATOMUSDT", "ADAUSDT", "TRXUSDT", "PEPEUSDT"]
CYCLE_INTERVAL_SECONDS=900
HUMAN_IN_LOOP=False

# ==========================================
# RISK PARAMETERS
# ==========================================
KELLY_FRACTION=0.25
MAX_DAILY_LOSS_PCT=0.05
MAX_POSITION_PCT=0.10

# ==========================================
# CONFIDENCE THRESHOLDS
# ==========================================
CONFIDENCE_THRESHOLD_DEFAULT=0.65
CONFIDENCE_THRESHOLD_HIGH_VOL=0.75
CONFIDENCE_THRESHOLD_UNKNOWN=0.80

# ==========================================
# SYSTEM PATHS
# ==========================================
CHROMA_PATH="./chroma_db"
LOG_LEVEL="INFO"